# Copie para .env.local e preencha. Nunca commite o .env.local.

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Só servidor — cria contas no 1º acesso, métricas, IA. NUNCA prefixar com NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# --- Domínio e lançamento ---
# URL pública canônica do site (metadataBase das OG images; baked no build).
NEXT_PUBLIC_SITE_URL=https://coworkingsocial.com.br
# Domínio que, antes do lançamento, serve só a landing (rotas da plataforma
# redirecionam pra "/"). Vazio = portão desligado (dev e outros deploys).
DOMINIO_LANDING=
# "sim" libera a plataforma no domínio principal (dia do lançamento; lida em
# runtime — basta reiniciar o serviço, sem rebuild).
PLATAFORMA_LIBERADA=nao

# --- Painel administrativo (/relatorios) ---
# Senha única compartilhada da coordenação (cookie de 12h).
PAINEL_SENHA=

# --- E-mail de confirmação de inscrição (Gmail SMTP) ---
GMAIL_USER=
# Senha de app (https://myaccount.google.com/apppasswords), não a senha da conta.
GMAIL_APP_PASSWORD=

# --- IA de apoio ao aluno (Ollama Cloud) ---
OLLAMA_API_KEY=
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_BASE_URL=https://ollama.com
# "true" liga o modo de raciocínio (modelos que suportam think).
OLLAMA_THINK=false

# --- Narração do tour guiado (offline; só para regerar os áudios) ---
# Usada apenas por scripts/gerar_narracao_elevenlabs.py — não é lida em runtime.
ELEVENLABS_API_KEY=

# --- Vídeo das aulas (Cloudflare R2, só servidor) ---
# Bucket privado; upload via presigned PUT, playback via presigned GET.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_VIDEOS=csmg-videos

# --- Transcodificação na Modal (sob demanda) ---
# URL do web endpoint da Modal (scripts/modal/transcode.py) + segredo que
# autentica o disparo e o callback /api/video/concluir. A Modal recebe só R2 +
# este segredo (nunca a service-role key).
MODAL_TRANSCODE_URL=
VIDEO_WEBHOOK_SECRET=
